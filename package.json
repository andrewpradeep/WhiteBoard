{
  "name": "whiteboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run download:speech-model",
    "build": "tsc && vite build",
    "debug:model": "playwright test tests/geometric-model.spec.ts --project=chromium --headed",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:model": "playwright test tests/geometric-model.spec.ts --project=chromium",
    "lint": "eslint v3/src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "download:speech-model": "node scripts/download-speech-model.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@reduxjs/toolkit": "^2.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.0.4",
    "redux": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/react-redux": "^7.1.33",
    "@types/redux": "^3.6.0",
    "@types/redux-thunk": "^2.1.0",
    "@types/webpack-env": "^1.18.4",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
